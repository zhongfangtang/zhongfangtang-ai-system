          {"step": "封面生成", "mode": "ai_auto", "description": "提取关键帧+文字叠加生成封面"},
          {"step": "多平台适配", "mode": "ai_auto", "description": "按各平台规格输出不同版本"},
          {"step": "人工审核", "mode": "manual", "description": "屈兵最终审核确认"}
