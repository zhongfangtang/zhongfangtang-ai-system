    {
      "id": "erp-agent",
      "name": "ERP同步官·小芳管家",
      "description": "用户数据、订单数据、私域数据与门店ERP/收银系统实时双向同步",
      "version": "1.0.0",
      "promptFile": "erp-agent.md",
      "trigger": "event_driven",
      "events": ["customer_create", "customer_update", "order_create", "order_update", "coupon_use", "visit_complete", "member_recharge"],
      "channels": ["cloud_function", "erp_api", "pos_api"],
      "model": "gemini-2.5-flash",
      "temperature": 0.2,
      "maxTokens": 4096,
      "contextWindow": 128000,
      "knowledgeBase": [
        "中芳堂ERP系统数据模型",
        "收银系统接口规范",
        "会员卡体系（储值卡/疗程卡/季卡/年卡）",
        "产品SKU映射表（小程序 ↔ ERP）",
        "服务项目映射表（小程序 ↔ ERP）",
        "员工信息与绩效计算规则",
        "库存管理规则",
        "财务对账规则"
      ],
      "rules": [
        "数据同步延迟不超过5秒",
        "同步失败自动重试3次，间隔30秒",
        "连续失败超过3次告警人工介入",
        "冲突数据以最后修改时间戳为准",
        "用户隐私数据（手机号/姓名）加密传输",
        "所有同步操作记录日志，保留90天",
        "每日凌晨自动对账，差异>0.1%告警",
        "禁止在小程序端直接暴露ERP原始数据",
        "敏感操作（退款/改价）需人工二次确认"
      ],
      "erpConfig": {
        "syncDirection": "bidirectional",
        "syncMode": "event_driven",
        "targetSystems": [
          {
            "name": "门店ERP",
            "type": "erp",
            "apiBase": "${ERP_API_BASE}",
            "authType": "api_key",
            "syncEntities": ["customer", "member_card", "order", "product", "inventory", "staff", "service_record"]
          },
          {
            "name": "收银系统",
            "type": "pos",
            "apiBase": "${POS_API_BASE}",
            "authType": "api_key",
            "syncEntities": ["transaction", "payment", "refund", "daily_report"]
          }
        ],
        "entityMapping": {
          "customer": {
            "cloudbaseField": "customers",
            "erpField": "t_customer",
            "syncFields": ["name", "phone", "gender", "birthday", "wechat_openid", "tizhi_type", "customer_level", "tags", "source", "created_at", "updated_at"],
            "conflictStrategy": "latest_wins"
          },
          "member_card": {
            "cloudbaseField": "member_cards",
            "erpField": "t_member_card",
            "syncFields": ["card_id", "customer_id", "card_type", "balance", "total_charged", "expiry_date", "status", "created_at", "updated_at"],
            "conflictStrategy": "latest_wins"
          },
          "order": {
            "cloudbaseField": "orders",
            "erpField": "t_order",
            "syncFields": ["order_id", "customer_id", "order_type", "items", "amount", "discount", "coupon_id", "payment_method", "status", "created_at", "updated_at"],
            "conflictStrategy": "latest_wins"
          },
          "product": {
            "cloudbaseField": "products",
            "erpField": "t_product",
            "syncFields": ["sku", "name", "category", "price", "cost", "stock", "unit", "description", "updated_at"],
            "conflictStrategy": "erp_wins"
          },
          "service_record": {
            "cloudbaseField": "service_records",
            "erpField": "t_service_record",
            "syncFields": ["record_id", "customer_id", "service_id", "staff_id", "start_time", "end_time", "satisfaction_score", "notes", "created_at"],
            "conflictStrategy": "latest_wins"
          }
        },
        "reconciliationSchedule": "0 2 * * *",
        "retryPolicy": {
          "maxRetries": 3,
          "retryInterval": 30000,
          "backoffMultiplier": 2
        }
      },
      "securityConfig": {
        "encryptionAlgorithm": "AES-256-GCM",
        "encryptedFields": ["phone", "name", "wechat_openid", "id_number"],
        "dataRetentionDays": 90,
        "accessControl": {
          "erp_read": ["admin", "manager", "erp-agent"],
          "erp_write": ["admin", "manager", "erp-agent"],
          "erp_delete": ["admin"]
        }
      }
    },
