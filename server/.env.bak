# ============================================================
# 中芳堂全域AI智能体系统 · 环境变量（已生成，可直接运行）
# ============================================================
#
# 使用说明：
#   本文件由 .env.example 生成，已填入占位值。系统在无密钥时
#   会自动降级为「演示/Mock 模式」启动，但真实发布/AI 调用等
#   功能需替换带 🔴 的字段后才能生效。
#
# 快速开始：
#   1. 把下面带 🔴 的字段替换成你的真实值
#   2. 启动：./scripts/start.sh   （或 docker compose up -d）
#   3. 健康检查：curl http://localhost:3001/health
#
# 成本原则：默认【免费/最低成本】方案，详见 .env.example 底部速查
# ============================================================

# ---------- 运行环境 ----------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ---------- 数据库（Docker内置，默认即可；改本地Mongo则改下方URI） ----------
MONGODB_URI=mongodb://127.0.0.1:27017/zhongfangtang
MONGODB_USER=
MONGODB_PASS=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT（🔴 生产必改：替换为随机长字符串） ----------
JWT_SECRET=__REPLACE_ME_random_long_secret_zhongfangtang_prod__
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================
# 🤖 AI 模型配置（低成本/免费优先，OpenAI 兼容格式）
# ============================================================
# 推荐：
#   A. 硅基流动 SiliconFlow（免费模型）  https://siliconflow.cn
#   B. DeepSeek（¥1/百万token，送额度）  https://platform.deepseek.com
# 🔴 必填：AI_MODEL_API_KEY
AI_MODEL_PROVIDER=openai-compatible
AI_MODEL_API_KEY=sk-__REPLACE_ME_siliconflow_or_deepseek_key__
AI_MODEL_API_SECRET=
AI_MODEL_ENDPOINT=https://api.siliconflow.cn/v1

# 模型名称（免费/低成本推荐）
AI_MODEL_TEXT=Qwen2.5-7B-Instruct
AI_MODEL_IMAGE=
AI_MODEL_EMBEDDING=

# ---------- 六平台 API ----------
# 全自动(full-auto)：百家号/B站/视频号；半自动(semi-auto)：抖音/小红书/快手
# 🔴 以下 6 组平台密钥按需填写（不填则该平台走「人工复核/待发布」队列，不报错）

# 抖音（semi-auto） 🔴
DOUYIN_APP_ID=__REPLACE_ME__
DOUYIN_APP_SECRET=__REPLACE_ME__
DOUYIN_REDIRECT_URI=https://admin.zhongfangtang.com/callback/douyin
DOUYIN_ACCESS_TOKEN=

# 小红书（semi-auto） 🔴
XIAOHONGSHU_APP_ID=__REPLACE_ME__
XIAOHONGSHU_APP_SECRET=__REPLACE_ME__
XIAOHONGSHU_REDIRECT_URI=https://admin.zhongfangtang.com/callback/xiaohongshu

# 微信视频号（full-auto，需企业认证） 🔴
WEIXIN_APP_ID=__REPLACE_ME__
WEIXIN_APP_SECRET=__REPLACE_ME__
WEIXIN_TOKEN=__REPLACE_ME__
WEIXIN_AES_KEY=__REPLACE_ME__

# 快手（semi-auto） 🔴
KUAISHOU_APP_ID=__REPLACE_ME__
KUAISHOU_APP_SECRET=__REPLACE_ME__
KUAISHOU_REDIRECT_URI=https://admin.zhongfangtang.com/callback/kuaishou

# B站（full-auto） 🔴
BILIBILI_APP_ID=__REPLACE_ME__
BILIBILI_APP_SECRET=__REPLACE_ME__
BILIBILI_REDIRECT_URI=https://admin.zhongfangtang.com/callback/bilibili
BILIBILI_ACCESS_KEY=
BILIBILI_REFRESH_TOKEN=

# 百家号（full-auto） 🔴
BAIJIAHAO_APP_ID=__REPLACE_ME__
BAIJIAHAO_APP_SECRET=__REPLACE_ME__
BAIJIAHAO_COOKIE=

# ---------- 企业微信 SCRM（免费） 🔴 对接私域必填 ----------
WEWORK_CORP_ID=
WEWORK_CORP_SECRET=
WEWORK_AGENT_ID=
WEWORK_TOKEN=
WEWORK_AES_KEY=
WEWORK_CALLBACK_URL=https://admin.zhongfangtang.com/wework/callback

# ---------- 微信小程序（与已有小程序API对接） 🔴 有小程序必填 ----------
MINIPROGRAM_APP_ID=
MINIPROGRAM_APP_SECRET=

# ---------- CRM/ERP 深度对接 ----------
# 通用美业ERP / 有赞美业 等（可选，配置后开启双向同步）
ERP_ENABLED=false
ERP_PROVIDER=youzan            # youzan | meituan | keruyun | generic
ERP_API_BASE=
ERP_API_KEY=
ERP_API_SECRET=
ERP_SHOP_ID=
# 腕家 H1 健康手表（可选，开启健康数据追踪）
WANJIA_H1_ENABLED=false
WANJIA_H1_API_BASE=https://api.wanjia-health.com/v1
WANJIA_H1_APP_KEY=
WANJIA_H1_APP_SECRET=

# ---------- Web3 链上存证 ----------
# 默认 Sepolia 测试网（免费）。主网见 .env.example 说明（Gas 费约 ¥300-800 一次性）
WEB3_ENABLED=false
WEB3_NETWORK=sepolia           # sepolia(免费测试网) | mainnet(以太坊主网) | polygon | bsc
WEB3_CHAIN_ID=11155111
WEB3_RPC_URL=https://rpc.sepolia.org
WEB3_CONTRACT_ADDRESS=        # 🔴 部署 Notary 合约后填入（见 contracts/deploy.js）
WEB3_PRIVATE_KEY=             # 🔴 仅「写入存证」需要；读取验证可留空

# ---------- 门店信息（宜昌） ----------
STORE_NAME=中芳堂中医芳香疗法
STORE_ADDRESS=湖北省宜昌市伍家岗区夷陵大道134号紫光园6号楼
STORE_PHONE=13227282079
STORE_LAT=30.69
STORE_LNG=111.29

# ---------- 内容审核 ----------
CONTENT_AUDIT_ENABLED=true
SENSITIVE_WORDS_FILE=./config/sensitive-words.txt

# ---------- 日志 ----------
LOG_LEVEL=info
LOG_DIR=./logs

# ============================================================
# 💡 免费方案速查
# ============================================================
# AI 调用：     硅基流动/DeepSeek 免费额度 → ¥0 起
# 服务器：      阿里云轻量 2核4G ¥99/月（香港节点免备案）
# 域名+SSL：    ¥7/年 + Let's Encrypt 免费
# 数据库备份：   OSS ¥10/月
# 平台发布：     百家号/B站 API 免费；其余半自动零API成本
# CDN/字体/图片：已全部本地化，¥0
# 月度总成本：   ≈ ¥186-316（详见《上线方案与web3-beauty集成最终方案.md》）
# Web3 上链：   测试网免费；主网部署合约 Gas 一次性 ¥300-800
# ============================================================
