# ============================================================
# 中芳堂全域AI智能体系统 · 环境变量配置模板
# ============================================================
#
# 使用方式：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 填入真实值（带 🔴 的必须填，否则系统无法真实运行）
#   3. 重启服务：docker compose restart api
#
# 成本原则：本模板默认采用【免费/最低成本】方案
#   - AI：硅基流动 SiliconFlow（有免费模型）或 DeepSeek（¥1/百万token，充值即送额度）
#   - 平台：百家号/B站 开放API 免费；抖音/小红书/快手 半自动（人工复核，零API成本）
#   - 字体/图片：已全部本地化，零外部成本
#
# ============================================================

# ---------- 运行环境 ----------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ---------- 跨域白名单（生产必配） ----------
# 允许访问本后端的看板/前端来源，逗号分隔（不要有空格引号）。
# 至少包含 BI 看板所在域名与你的自定义域名；部署到 Render 后也可追加其自动子域名。
CORS_ORIGINS=https://www.htmlcode.fun,https://zft.51gaozhan.com

# ---------- 数据库（Docker内置，默认即可） ----------
MONGODB_URI=mongodb://127.0.0.1:27017/zhongfangtang
MONGODB_USER=
MONGODB_PASS=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT ----------
JWT_SECRET=请改为随机长字符串-zhongfangtang-prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================
# 🤖 AI 模型配置（低成本/免费优先）
# ============================================================
#
# 推荐方案（按成本从低到高）：
#   A. 硅基流动 SiliconFlow —— 有免费模型(Qwen2.5-7B/DeepSeek-V2-Lite等)，OpenAI兼容
#       endpoint: https://api.siliconflow.cn/v1
#       API Key: 注册送免费额度 https://siliconflow.cn
#   B. DeepSeek —— ¥1/百万token输入，充值即送额度，OpenAI兼容
#       endpoint: https://api.deepseek.com/v1
#       API Key: https://platform.deepseek.com
#   C. 通义千问 Qwen —— 有免费额度(100万token)，dashscope格式
#       endpoint: https://dashscope.aliyuncs.com/api/v1
#
# 默认采用方案 A（免费额度最大），格式为 OpenAI 兼容
AI_MODEL_PROVIDER=openai-compatible
AI_MODEL_API_KEY=sk-你的硅基流动或DeepSeek密钥
AI_MODEL_API_SECRET=
AI_MODEL_ENDPOINT=https://api.siliconflow.cn/v1

# 模型名称（免费/低成本推荐）
#   硅基流动免费: Qwen2.5-7B-Instruct / DeepSeek-V2.5
#   DeepSeek:     deepseek-chat
#   通义千问:     qwen-plus
AI_MODEL_TEXT=Qwen2.5-7B-Instruct
AI_MODEL_IMAGE=
AI_MODEL_EMBEDDING=

# ---------- 六平台 API（免费开放API优先） ----------
# 发布模式说明：
#   full-auto 全自动 = 百家号/B站/视频号（低风险，直接API发布）
#   semi-auto 半自动 = 抖音/小红书/快手（AI预审+人工复核，零API封号风险）

# 抖音（semi-auto，需申请开放平台权限） 🔴
DOUYIN_APP_ID=
DOUYIN_APP_SECRET=
DOUYIN_REDIRECT_URI=
DOUYIN_ACCESS_TOKEN=

# 小红书（semi-auto，开放平台内测） 🔴
XIAOHONGSHU_APP_ID=
XIAOHONGSHU_APP_SECRET=
XIAOHONGSHU_REDIRECT_URI=

# 微信视频号（full-auto，需企业认证） 🔴
WEIXIN_APP_ID=
WEIXIN_APP_SECRET=
WEIXIN_TOKEN=
WEIXIN_AES_KEY=

# 快手（semi-auto，需服务商资质） 🔴
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
KUAISHOU_REDIRECT_URI=

# B站（full-auto，创作中心API免费） 🔴
BILIBILI_APP_ID=
BILIBILI_APP_SECRET=
BILIBILI_REDIRECT_URI=
BILIBILI_ACCESS_KEY=
BILIBILI_REFRESH_TOKEN=

# 百家号（full-auto，百度开放API免费） 🔴
BAIJIAHAO_APP_ID=
BAIJIAHAO_APP_SECRET=
BAIJIAHAO_COOKIE=

# ---------- 企业微信（免费） ----------
WEWORK_CORP_ID=
WEWORK_CORP_SECRET=
WEWORK_AGENT_ID=
WEWORK_TOKEN=
WEWORK_AES_KEY=
WEWORK_CALLBACK_URL=

# ---------- 微信小程序（与已有小程序API对接） ----------
MINIPROGRAM_APP_ID=
MINIPROGRAM_APP_SECRET=

# ---------- CRM/ERP 深度对接 ----------
# 通用美业ERP / 有赞美业 / 美团收银 / 客如云（配置后开启双向同步）
ERP_ENABLED=false
ERP_PROVIDER=generic            # generic | youzan | meituan | keruyun
ERP_API_BASE=
ERP_API_KEY=                    # 🔴 开启同步必填
ERP_API_SECRET=
ERP_SHOP_ID=
# 腕家 H1 健康手表（开启健康数据追踪）
WANJIA_H1_ENABLED=false
WANJIA_H1_API_BASE=https://api.wanjia-health.com/v1
WANJIA_H1_APP_KEY=              # 🔴 开启同步必填
WANJIA_H1_APP_SECRET=

# ---------- 门店信息（宜昌） ----------
STORE_NAME=中芳堂中医芳香疗法
STORE_ADDRESS=湖北省宜昌市伍家岗区夷陵大道134号紫光园6号楼
STORE_PHONE=13227282079
STORE_LAT=30.69
STORE_LNG=111.29

# ---------- Web3 链上存证 ----------
# 默认 Sepolia 测试网（免费）。主网见底部说明（Gas 费约 ¥300-800 一次性）
WEB3_ENABLED=false
WEB3_NETWORK=sepolia           # sepolia(免费测试网) | mainnet(以太坊主网) | polygon | bsc
WEB3_CHAIN_ID=11155111
WEB3_RPC_URL=https://rpc.sepolia.org
WEB3_CONTRACT_ADDRESS=        # 🔴 部署 Notary 合约后填入（见 contracts/deploy.js）
WEB3_PRIVATE_KEY=             # 🔴 仅「写入存证」需要；读取验证可留空

# ---------- 内容审核 ----------
CONTENT_AUDIT_ENABLED=true
SENSITIVE_WORDS_FILE=./config/sensitive-words.txt

# ---------- 日志 ----------
LOG_LEVEL=info
LOG_DIR=./logs

# ============================================================
# 💡 免费方案速查
# ============================================================
# AI 调用：     硅基流动/DeepSeek 免费额度 → ¥0 起
# 服务器：      阿里云轻量 2核4G ¥99/月（香港节点免备案）
# 域名+SSL：    ¥7/年 + Let's Encrypt 免费
# 数据库备份：   OSS ¥10/月
# 平台发布：     百家号/B站 API 免费；其余半自动零API成本
# CDN/字体/图片：已全部本地化，¥0
# 月度总成本：   ≈ ¥186-316（详见《上线方案与web3-beauty集成最终方案.md》）
# ============================================================
